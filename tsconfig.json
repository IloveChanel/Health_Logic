{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["jest", "node"]
  },
  "exclude": [
    "audit",
    "audit/**/*",
    "_repair_backup*",
    "_repair_backup*/**/*",
    "**/_repair_backup*",
